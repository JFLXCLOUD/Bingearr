# Copy to .env and adjust. All vars are prefixed BINGEARR_.

# Network
BINGEARR_HOST=0.0.0.0
BINGEARR_PORT=9494

# Where the SQLite db + generated api key live.
BINGEARR_DATA_DIR=data

# Leave empty to auto-generate a key on first run (printed in the log,
# persisted in the db). Set explicitly to pin it.
BINGEARR_API_KEY=

# Plex client request timeout (seconds).
BINGEARR_PLEX_TIMEOUT=30
