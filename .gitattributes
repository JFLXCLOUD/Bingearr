# Normalize line endings to LF in the repo; checkout native on each OS.
# Keeps the tree clean for Docker/Linux while allowing CRLF on Windows.
* text=auto eol=lf

# Explicitly LF for source and config (these run in Linux containers).
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf
Dockerfile text eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.db    binary
*.sqlite binary
